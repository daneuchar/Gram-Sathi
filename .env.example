# AWS Bedrock
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-south-1
BEDROCK_MODEL_ID=us.meta.llama3-3-70b-instruct-v1:0

# Sarvam AI
SARVAM_API_KEY=

# External APIs
DATA_GOV_API_KEY=

# Database (override in docker-compose, keep for local dev)
DATABASE_URL=postgresql+asyncpg://gramvaani:gramvaani@localhost:5432/gramvaani

# LiveKit (override in docker-compose, keep for local dev)
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# App
DEBUG=false

# Deployment — set these to your EC2 public IP/domain
# PUBLIC_URL=http://<EC2_PUBLIC_IP>:8000
# LIVEKIT_PUBLIC_URL=ws://<EC2_PUBLIC_IP>:7880
